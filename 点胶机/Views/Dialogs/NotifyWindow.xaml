<mah:MetroWindow x:Class="点胶机.Views.Dialogs.NotifyWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:vm="clr-namespace:点胶机.ViewModels"
                 d:DataContext="{d:DesignInstance Type=vm:NotifyDialogViewModel}"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 mc:Ignorable="d"
                 Title="提示" Height="240" Width="440"
                 ResizeMode="NoResize"
                 WindowStartupLocation="CenterOwner"
                 TitleCharacterCasing="Normal"
                 WindowTitleBrush="{Binding TitleBarBrush}"
                 ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 消息内容区 -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center" Orientation="Horizontal">
            <!-- 图标(按类型变色) -->
            <TextBlock Text="{Binding IconChar}" FontSize="48" Foreground="{Binding IconBrush}"
                       VerticalAlignment="Center" Margin="0,0,16,0" />
            <TextBlock Text="{Binding Message}" FontSize="16" TextWrapping="Wrap"
                       VerticalAlignment="Center" MaxWidth="320" />
        </StackPanel>

        <!-- 按钮区 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="确认" Padding="24,6" Command="{Binding ConfirmCommand}"
                    Visibility="{Binding ConfirmVisible}" />
            <Button Content="取消" Padding="24,6" Margin="8,0,0,0" Command="{Binding CancelCommand}"
                    Visibility="{Binding CancelVisible}" />
        </StackPanel>
    </Grid>
</mah:MetroWindow>
