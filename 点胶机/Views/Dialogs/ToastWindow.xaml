<Window x:Class="点胶机.Views.Dialogs.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:toast="clr-namespace:点胶机.Services.Toast"
        Title="通知" Height="420" Width="380"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize"
        Topmost="True" ShowActivated="False">
    <!-- 右下角非模态:由 code-behind 定位到屏幕右下角 -->
    <Border Background="#F2323338" CornerRadius="8" Margin="6" Opacity="0.97">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.5" Color="Black" />
        </Border.Effect>
        <DockPanel LastChildFill="True">
            <!-- 顶部标题栏 + 关闭按钮 -->
            <Border DockPanel.Dock="Top" Background="#24292E" CornerRadius="8,8,0,0" Padding="12,8">
                <DockPanel LastChildFill="False">
                    <TextBlock Text="🔔 通知" Foreground="White" FontWeight="Bold" FontSize="13" DockPanel.Dock="Left" VerticalAlignment="Center" />
                    <!-- 筛选下拉 -->
                    <ComboBox x:Name="FilterBox" DockPanel.Dock="Left" Margin="12,0,0,0" Width="92" FontSize="11"
                              SelectedIndex="0" SelectionChanged="OnFilterChanged">
                        <ComboBoxItem Content="全部" Tag="-1" />
                        <ComboBoxItem Content="错误" Tag="2" />
                        <ComboBoxItem Content="警告" Tag="1" />
                        <ComboBoxItem Content="讯息" Tag="0" />
                    </ComboBox>
                    <TextBlock Text="清空" Foreground="#9DA5B3" FontSize="11" Cursor="Hand" DockPanel.Dock="Right"
                               VerticalAlignment="Center" Margin="8,0" MouseDown="OnClear" />
                    <TextBlock Text="✕ 关闭" Foreground="#9DA5B3" FontSize="11" Cursor="Hand" DockPanel.Dock="Right"
                               VerticalAlignment="Center" MouseDown="OnClose" />
                </DockPanel>
            </Border>

            <!-- 通知列表 -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
                <ItemsControl x:Name="List" Padding="6">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2D3138" CornerRadius="4" Margin="4,3" Padding="8,6">
                                <DockPanel LastChildFill="True">
                                    <!-- 左侧等级色条 -->
                                    <Border Width="4" Background="{Binding LevelColor}" CornerRadius="2" DockPanel.Dock="Left" />
                                    <StackPanel Margin="8,0,0,0">
                                        <!-- 标题行 -->
                                        <DockPanel LastChildFill="False">
                                            <TextBlock Text="{Binding LevelText}" FontWeight="Bold" FontSize="11" DockPanel.Dock="Left"
                                                       Foreground="{Binding LevelColor}" />
                                            <TextBlock Text="{Binding Title}" Foreground="White" FontSize="12" FontWeight="Bold"
                                                       DockPanel.Dock="Left" Margin="6,0,0,0" />
                                        </DockPanel>
                                        <!-- 消息 -->
                                        <TextBlock Text="{Binding Message}" Foreground="#D0D4D9" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0" />
                                        <!-- 时间 -->
                                        <TextBlock Text="{Binding Time, StringFormat=HH:mm:ss}" Foreground="#6E7681" FontSize="10" Margin="0,3,0,0" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
