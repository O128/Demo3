<UserControl x:Class="点胶机.Views.Pages.AutoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:点胶机.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:AutoViewModel}"
             mc:Ignorable="d">
    <UserControl.Resources>
        <!-- 节点状态 → 颜色/边框样式 -->
        <Style x:Key="FlowNodeBorder" TargetType="Border">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="Margin" Value="0,4" />
            <Setter Property="Background" Value="#3A3A3A" />
            <Setter Property="BorderBrush" Value="#555555" />
            <Style.Triggers>
                <!-- 已完成:淡绿 -->
                <DataTrigger Binding="{Binding State}" Value="Done">
                    <Setter Property="Background" Value="#2E7D32" />
                    <Setter Property="BorderBrush" Value="#66BB6A" />
                </DataTrigger>
                <!-- 当前执行:高亮蓝 + 粗边框 -->
                <DataTrigger Binding="{Binding State}" Value="Active">
                    <Setter Property="Background" Value="#1565C0" />
                    <Setter Property="BorderBrush" Value="#42A5F5" />
                    <Setter Property="BorderThickness" Value="3" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FlowNodeTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="Active">
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="FontSize" Value="15" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FlowNodeSubtitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9E9E9E" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <!-- 箭头样式 -->
        <Style x:Key="FlowArrow" TargetType="TextBlock">
            <Setter Property="Text" Value="►" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#757575" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="2,0" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />   <!-- 顶端状态条 -->
            <RowDefinition Height="Auto" />   <!-- 控制按钮 -->
            <RowDefinition Height="*" />       <!-- 流程图 -->
            <RowDefinition Height="Auto" />   <!-- 步序详情 + 产量 -->
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="22" FontWeight="Bold" Margin="0,0,0,12" />

        <!-- ===== 顶端状态条(颜色随运行状态联动)===== -->
        <Border Grid.Row="1" Background="{Binding RunStatusColor}" CornerRadius="4" Padding="14,8" Margin="0,0,0,12">
            <DockPanel LastChildFill="False">
                <TextBlock Text="●" FontSize="20" Foreground="White" VerticalAlignment="Center" DockPanel.Dock="Left" />
                <TextBlock Text="{Binding RunStatusText}" FontSize="18" FontWeight="Bold" Foreground="White"
                           VerticalAlignment="Center" DockPanel.Dock="Left" Margin="8,0,0,0" />
                <TextBlock VerticalAlignment="Center" Foreground="White" Opacity="0.85" DockPanel.Dock="Right">
                    <Run Text="当前步序: " />
                    <Run Text="{Binding WorkStep}" FontWeight="Bold" />
                    <Run Text="  |  " />
                    <Run Text="{Binding StepDesc}" />
                </TextBlock>
            </DockPanel>
        </Border>

        <!-- ===== 控制按钮(启动/暂停在手动模式禁用;停止/复位始终可用——安全按钮)===== -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="启动" Padding="20,8" Background="#43A047" Foreground="White" Command="{Binding StartCommand}" Margin="0,0,8,0"
                    IsEnabled="{Binding IsAutoRunEnabled}" />
            <Button Content="暂停" Padding="20,8" Background="#FB8C00" Foreground="White" Command="{Binding PauseCommand}" Margin="0,0,8,0"
                    IsEnabled="{Binding IsAutoRunEnabled}" />
            <Button Content="停止" Padding="20,8" Background="#E53935" Foreground="White" Command="{Binding StopRunCommand}" Margin="0,0,8,0" />
            <Button Content="复位" Padding="20,8" Command="{Binding ResetCommand}" />
        </StackPanel>

        <!-- ===== 流程图(横向,自动换行)===== -->
        <Border Grid.Row="3" Padding="16" CornerRadius="6" Background="{DynamicResource MahApps.Brushes.Control.Background}">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Nodes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" ItemHeight="70" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- 节点 -->
                                <Border Style="{StaticResource FlowNodeBorder}">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource FlowNodeTitle}" Text="{Binding Title}" />
                                        <TextBlock Style="{StaticResource FlowNodeSubtitle}" Text="{Binding Subtitle}" />
                                    </StackPanel>
                                </Border>
                                <!-- 箭头(最后一个节点不显示——通过 Index 判断,这里统一显示,循环含义由"完成→待机"表达) -->
                                <TextBlock Style="{StaticResource FlowArrow}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ===== 步序详情 + 产量 ===== -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,16,0,0">
            <Border Padding="16,8" CornerRadius="6" Background="{DynamicResource MahApps.Brushes.Control.Background}" Margin="0,0,12,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="今日产量: " FontSize="16" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding TodayYield}" FontSize="26" FontWeight="Bold" Foreground="#66BB6A" VerticalAlignment="Center" Margin="8,0,0,0" />
                    <TextBlock Text=" 片" FontSize="16" VerticalAlignment="Center" />
                </StackPanel>
            </Border>
            <Border Padding="16,8" CornerRadius="6" Background="{DynamicResource MahApps.Brushes.Control.Background}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="图例: " FontSize="12" VerticalAlignment="Center" Opacity="0.7" />
                    <Border Background="#3A3A3A" BorderBrush="#555" BorderThickness="2" CornerRadius="3" Padding="8,2" Margin="6,0">
                        <TextBlock Text="待执行" FontSize="11" />
                    </Border>
                    <Border Background="#2E7D32" BorderBrush="#66BB6A" BorderThickness="2" CornerRadius="3" Padding="8,2" Margin="6,0">
                        <TextBlock Text="已完成" FontSize="11" />
                    </Border>
                    <Border Background="#1565C0" BorderBrush="#42A5F5" BorderThickness="3" CornerRadius="3" Padding="8,2" Margin="6,0">
                        <TextBlock Text="执行中" FontSize="11" />
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
