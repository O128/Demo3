<UserControl x:Class="点胶机.Views.Pages.RecipeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:vm="clr-namespace:点胶机.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:RecipeViewModel}"
             mc:Ignorable="d">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="22" FontWeight="Bold" Margin="0,0,0,12" />

        <!-- 参数 -->
        <Border Grid.Row="1" Padding="12" CornerRadius="6" Background="{DynamicResource MahApps.Brushes.Control.Background}" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="配方名: " VerticalAlignment="Center" />
                <TextBox Text="{Binding Recipe.Name}" Width="120" Margin="0,0,16,0" />
                <TextBlock Text="点胶速度: " VerticalAlignment="Center" />
                <mah:NumericUpDown Value="{Binding DispenseSpeed}" Width="100" Margin="0,0,16,0" />
                <TextBlock Text="胶量(mg/ms): " VerticalAlignment="Center" />
                <mah:NumericUpDown Value="{Binding GlueFlow}" Width="100" Margin="0,0,16,0" />
                <Button Content="保存" Padding="14,4" Command="{Binding SaveCommand}" Margin="8,0" />
                <Button Content="重载" Padding="14,4" Command="{Binding ReloadCommand}" />
            </StackPanel>
        </Border>

        <!-- 轨迹点表格 -->
        <Border Grid.Row="2" CornerRadius="6" Background="{DynamicResource MahApps.Brushes.Control.Background}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="8">
                    <TextBlock Text="点胶轨迹点" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                    <Button Content="添加点" Padding="10,2" Command="{Binding AddPointCommand}" Margin="16,0,8,0" />
                    <Button Content="清空" Padding="10,2" Command="{Binding ClearPointsCommand}" />
                </StackPanel>
                <DataGrid ItemsSource="{Binding Recipe.Points}" AutoGenerateColumns="False"
                          CanUserAddRows="True" CanUserDeleteRows="True" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="X(mm)" Binding="{Binding X}" Width="*" />
                        <DataGridTextColumn Header="Y(mm)" Binding="{Binding Y}" Width="*" />
                        <DataGridTextColumn Header="Z(mm)" Binding="{Binding Z}" Width="*" />
                        <DataGridCheckBoxColumn Header="开胶" Binding="{Binding GlueOn}" Width="60" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
