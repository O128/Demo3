<UserControl x:Class="点胶机.Views.Pages.ManualView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
             xmlns:enum="clr-namespace:点胶机.Core.Enums"
             xmlns:vm="clr-namespace:点胶机.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:ManualViewModel}"
             mc:Ignorable="d">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="22" FontWeight="Bold" Margin="0,0,0,8" />

        <!-- 禁用横幅:自动模式/运行中时显示 -->
        <Border Grid.Row="0" VerticalAlignment="Bottom"
                Background="#E53935" CornerRadius="4" Padding="12,6" Margin="0,0,0,12"
                Visibility="{Binding IsDisabled, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding DisabledReason}" Foreground="White" FontWeight="Bold" />
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">

            <StackPanel>
                <!-- 当前位置显示 -->
                <Border Padding="16" CornerRadius="6" Background="{DynamicResource MahApps.Brushes.Control.Background}" Margin="0,0,0,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="当前位置: " FontSize="14" />
                        <TextBlock Text="{Binding PosX, StringFormat=X:{0:F2}}" Margin="8,0" />
                        <TextBlock Text="{Binding PosY, StringFormat=Y:{0:F2}}" Margin="8,0" />
                        <TextBlock Text="{Binding PosZ, StringFormat=Z:{0:F2}}" Margin="8,0" />
                    </StackPanel>
                </Border>

                <!-- 轴选择 + 操作(运行类按钮:自动模式/运行中禁用) -->
                <Border Padding="16" CornerRadius="6" Background="{DynamicResource MahApps.Brushes.Control.Background}" Margin="0,0,0,12"
                        IsEnabled="{Binding IsDisabled, Converter={StaticResource NotConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="选择轴:" VerticalAlignment="Center" Margin="0,8" />
                        <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding AxisOptions}" SelectedItem="{Binding SelectedAxis}" Margin="8" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="目标位置:" VerticalAlignment="Center" Margin="16,8,0,8" />
                        <mah:NumericUpDown Grid.Row="0" Grid.Column="3"
                                           Value="{Binding TargetPos}" Margin="8" />
                        <TextBlock Grid.Row="0" Grid.Column="4" Text="速度:" VerticalAlignment="Center" Margin="16,8,0,8" />
                        <mah:NumericUpDown Grid.Row="0" Grid.Column="5" Value="{Binding MoveSpeed}" Margin="8" Minimum="1" />

                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="6" Orientation="Horizontal" Margin="0,8">
                            <Button Content="伺服上电" Padding="14,6" Command="{Binding ServoOnCommand}" Margin="0,0,8,0" />
                            <Button Content="伺服下电" Padding="14,6" Command="{Binding ServoOffCommand}" Margin="0,0,8,0" />
                            <Button Content="回零" Padding="14,6" Command="{Binding HomeCommand}" Margin="0,0,8,0" />
                            <Button Content="绝对定位" Padding="14,6" Command="{Binding MoveAbsCommand}" Margin="0,0,8,0" />
                            <Button Content="停止" Padding="14,6" Command="{Binding StopCommand}" Background="OrangeRed" />
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="6" Orientation="Horizontal" Margin="0,8">
                            <TextBlock Text="JOG:" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <Button Content="◄ 负向" Padding="14,6" Command="{Binding JogNegCommand}" Margin="0,0,8,0" />
                            <Button Content="正向 ►" Padding="14,6" Command="{Binding JogPosCommand}" Margin="0,0,8,0" />
                            <Button Content="停止 JOG" Padding="14,6" Command="{Binding JogStopCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 胶阀测试(运行类按钮:自动模式/运行中禁用) -->
                <Border Padding="16" CornerRadius="6" Background="{DynamicResource MahApps.Brushes.Control.Background}"
                        IsEnabled="{Binding IsDisabled, Converter={StaticResource NotConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="点胶阀测试: " VerticalAlignment="Center" />
                        <Button Content="开胶" Padding="14,6" Command="{Binding GlueOpenCommand}" Background="LawnGreen" Margin="8,0" />
                        <Button Content="关胶" Padding="14,6" Command="{Binding GlueCloseCommand}" Background="OrangeRed" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
