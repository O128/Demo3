    "Y": { "PulseUnit": 1000, "SoftLimitPositive": 300, "SoftLimitNegative": -10, "RunSpeed": 100, "HomeSpeed": 20 },
    "Z": { "PulseUnit": 1000, "SoftLimitPositive": 100, "SoftLimitNegative": -10, "RunSpeed": 50, "HomeSpeed": 10 }
  },
  "Database": {
    "ConnectionString": "Server=localhost;Port=3306;Database=dispenser;Uid=root;Pwd=YOUR_MYSQL_PASSWORD;",
    "AutoCreateTable": true
  },
  "Logging": {
    "MinLevel": "Debug",
    "FilePath": "logs/log.txt"
  },
  "Scheduler": {
    "ThreadCount": 4,
    "TickIntervalMs": 1
