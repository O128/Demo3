{
  "Machine": {
    "Name": "Dispenser-01",
    "Version": "V1.0.1"
  },
  "Hardware": {
    "NoHardwareMode": true,
    "Plc": {
      "Mode": "Sim",
      "ScanCycleMs": 1
    },
    "Vision": {
      "SimDelayMs": 500
    }
  },
  "Axes": {
