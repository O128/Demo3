<mah:MetroWindow x:Class="点胶机.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
                 xmlns:vm="clr-namespace:点胶机.ViewModels"
                 d:DataContext="{d:DesignInstance Type=vm:ShellViewModel}"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 mc:Ignorable="d"
                 TitleCharacterCasing="Normal"
                 Title="点胶机自动控制系统 V1.0.1" Height="720" Width="1280"
                 MinHeight="600" MinWidth="1024"
                 WindowTitleBrush="{DynamicResource MahApps.Brushes.Accent}"
                   NonActiveWindowTitleBrush="{DynamicResource MahApps.Brushes.Accent}"
                   GlowBrush="{DynamicResource MahApps.Brushes.Accent}"
                   BorderThickness="1"
                   ShowTitleBar="True"
                   TitleAlignment="Left">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- 顶部状态条 -->
            <RowDefinition Height="*" />      <!-- 主区域 -->
        </Grid.RowDefinitions>

        <!-- ========== 顶部状态条 ========== -->
        <Border Grid.Row="0" Background="{DynamicResource MahApps.Brushes.Accent}" Padding="12,8">
            <DockPanel LastChildFill="True">
                <!-- 机器名/版本 -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <iconPacks:PackIconMaterial Kind="RobotIndustrial" Width="22" Height="22" VerticalAlignment="Center" />
                    <TextBlock Text="点胶机自动控制系统" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="6,0,0,0" />
                    <TextBlock Text="Dispenser-01 | V1.0.1" FontSize="11" Opacity="0.7" VerticalAlignment="Center" Margin="10,0,0,0" />
                </StackPanel>

                <!-- 控制按钮 -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <!-- 手/自动切换(互斥) -->
                    <Button Content="手动模式" Margin="3,0" Padding="12,4" Command="{Binding SwitchToManualCommand}" ToolTip="切换到手动模式(自动流程暂停)" />
                    <Button Content="自动模式" Margin="3,0" Padding="12,4" Command="{Binding SwitchToAutoCommand}" ToolTip="切换到自动模式(续跑或从头开始)" Background="#1565C0" Foreground="White" />
                    <Rectangle Width="1" Fill="#888" Margin="6,4" />
                    <Button Content="复位" Margin="3,0" Padding="14,4" Command="{Binding ResetCommand}" />
                    <Button Content="启动" Margin="3,0" Padding="14,4" Background="Green" Command="{Binding StartCommand}" IsEnabled="{Binding IsAutoRunEnabled}" />
                    <Button Content="暂停" Margin="3,0" Padding="14,4" Command="{Binding PauseCommand}" IsEnabled="{Binding IsAutoRunEnabled}" />
                    <Button Content="停止" Margin="3,0" Padding="14,4" Command="{Binding StopCommand}" />
                    <Button Content="急停" Margin="6,0,0,0" Padding="14,4" Background="{Binding EstopColor}" FontWeight="Bold" Command="{Binding EstopCommand}" />
                </StackPanel>

                <!-- 机器名/版本(移到中间左侧之后,这里改为空) -->
                <TextBlock Text="" />

                <!-- 中间运行状态 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="运行状态:" VerticalAlignment="Center" />
                    <TextBlock Text="●" FontSize="18" Foreground="{Binding RunStatusColor}" VerticalAlignment="Center" Margin="6,0,3,0" />
                    <TextBlock Text="{Binding RunStatusText}" VerticalAlignment="Center" FontWeight="Bold" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ========== 主区域:左导航 + 内容 ========== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />   <!-- 左导航 -->
                <ColumnDefinition Width="*" />      <!-- 内容承载 -->
            </Grid.ColumnDefinitions>

            <!-- 左侧导航菜单 -->
            <Border Grid.Column="0" Background="{DynamicResource MahApps.Brushes.WindowTitle}">
                <DockPanel LastChildFill="True">
                    <ListBox x:Name="NavList" DockPanel.Dock="Top" Background="Transparent" BorderThickness="0"
                             SelectedIndex="0" Margin="0,8">
                        <ListBoxItem Padding="14,10">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="ViewDashboard" Width="20" Height="20" VerticalAlignment="Center" />
                                <TextBlock Text="主页" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Padding="14,10"
                                     IsEnabled="{Binding IsManualEnabled}"
                                     ToolTip="{Binding ManualDisabledReason}">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="Cog" Width="20" Height="20" VerticalAlignment="Center" />
                                <TextBlock Text="手动" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Padding="14,10">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="PlayCircle" Width="20" Height="20" VerticalAlignment="Center" />
                                <TextBlock Text="自动" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Padding="14,10">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="ClipboardListOutline" Width="20" Height="20" VerticalAlignment="Center" />
                                <TextBlock Text="配方" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Padding="14,10">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="AlertCircleOutline" Width="20" Height="20" VerticalAlignment="Center" />
                                <TextBlock Text="报警" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Padding="14,10">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="FileDocumentOutline" Width="20" Height="20" VerticalAlignment="Center" />
                                <TextBlock Text="日志" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Padding="14,10">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="ToggleSwitchOutline" Width="20" Height="20" VerticalAlignment="Center" />
                                <TextBlock Text="IO 监控" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Padding="14,10">
                            <StackPanel Orientation="Horizontal">
                                <iconPacks:PackIconMaterial Kind="CogOutline" Width="20" Height="20" VerticalAlignment="Center" />
                                <TextBlock Text="设置" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>

                    <!-- 左下角:机器名/工作模式 -->
                    <Border DockPanel.Dock="Bottom" Padding="14,10" BorderThickness="0,1,0,0"
                            BorderBrush="{DynamicResource MahApps.Brushes.Gray8}">
                        <StackPanel>
                            <TextBlock FontSize="11" Opacity="0.8">
                                <Run Text="工作模式: " /><Run Text="{Binding WorkModeText}" FontWeight="Bold" />
                            </TextBlock>
                            <TextBlock FontSize="11" Opacity="0.8" Margin="0,4,0,0">
                                <Run Text="就绪状态: " /><Run Text="{Binding ReadyStatusText}" FontWeight="Bold" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Border>

            <!-- 内容承载区(ContentControl 切换 UserControl) -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentView}" Margin="0" />
        </Grid>
    </Grid>
</mah:MetroWindow>
